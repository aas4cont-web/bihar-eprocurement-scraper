# Bihar eProcurement Scraper Configuration

# Portal URL
BIHAR_PORTAL_URL=https://eproc2.bihar.gov.in/EPSV2Web/openarea/tenderListingPage.action

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bihar_tenders
DB_USER=scraper
DB_PASSWORD=scraper_password
DB_SSL=false

# Browser
HEADLESS=true
BROWSER_TIMEOUT=30000
MODAL_TIMEOUT=15000

# Scraper
LOG_LEVEL=info
LOG_DIR=./logs
SCREENSHOT_DIR=./screenshots
CAPTURE_SCREENSHOTS_ON_FAILURE=true

# Retry
MAX_RETRIES=3
RETRY_DELAY_MS=2000
WAIT_STABILITY_TIME_MS=1000
WAIT_STABILITY_CHECKS=3

# Performance
MAX_CONCURRENT_OPERATIONS=1
DISPOSE_AFTER_TENDER=true
